#!/bin/sh
# Pre-commit: run the fast CI gates for whichever layer the staged changes touch.
# Enable per clone: git config core.hooksPath .githooks   (bypass: git commit --no-verify)
set -e

staged=$(git diff --cached --name-only)

# Rust engine + CLI: clippy (-D warnings) on the engine, tests on both crates —
# mirrors CI's `core` job. Triggers on crates/ or workspace manifest changes.
if printf '%s\n' "$staged" | grep -qE '^(crates/|Cargo\.(toml|lock)$)'; then
    echo "pre-commit: cargo clippy -p slideflow-core --all-targets -- -D warnings"
    cargo clippy -p slideflow-core --all-targets -- -D warnings

    echo "pre-commit: cargo test -p slideflow-core -p slideflow-cli"
    cargo test -p slideflow-core -p slideflow-cli --quiet
fi

# Frontend: typecheck + tray-model tests when apps/desktop/src changes. Skips the
# slow vite build (tsc catches the common CI break; the full build stays in CI).
# Gracefully no-ops if deps aren't installed rather than blocking the commit.
if printf '%s\n' "$staged" | grep -qE '^apps/desktop/src/'; then
    if [ -x apps/desktop/node_modules/.bin/tsc ]; then
        echo "pre-commit: tsc --noEmit && pnpm test:tray (apps/desktop)"
        ( cd apps/desktop && ./node_modules/.bin/tsc --noEmit && pnpm test:tray )
    else
        echo "pre-commit: SKIP frontend checks — apps/desktop/node_modules missing (cd apps/desktop && pnpm install)"
    fi
fi
