{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slideflow",
  "version": "0.2.3",
  "identifier": "com.slideflow.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Slideflow",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 20 },
        "theme": null
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/thumbs/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Search your slides, compose new decks with original fidelity.",
    "longDescription": "Slideflow indexes every slide across your presentation folders, lets you search them instantly, and compose brand-new decks that preserve each slide's original theme, master and formatting."
  }
}
